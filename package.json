{
  "name": "soccer-coaching-hub",
  "version": "1.0.0",
  "description": "A platform for soccer coaches to create practice plans, coordinate with other coaches, and communicate with parents.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"**/*.md\"",
    "test": "echo \"No tests yet\" && exit 0",
    "ci": "npm run format:check && npm run lint && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goblinsan/soccer-coaching-hub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/goblinsan/soccer-coaching-hub/issues"
  },
  "homepage": "https://github.com/goblinsan/soccer-coaching-hub#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
